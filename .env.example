# Copy to .env or export these before running the CLI / deploy scripts. Nothing
# here is secret — these are deployment coordinates, not credentials.

# Region — must be one where Lambda MicroVMs is available. All resources
# (artifact bucket, image, MicroVMs) co-locate in this region. Used by SAM
# (samconfig.toml pins us-west-2), the deploy scripts, and the CLI.
AWS_REGION=us-west-2

# The admin CLI (create-user / run-room / prune-images) needs the account ID to
# build MicroVM ARNs:
#   export AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
AWS_ACCOUNT_ID=123456789012

# Optional overrides (sensible defaults exist in code):
# STACK_NAME=asteroids
# MICROVM_IMAGE_NAME=asteroids
