# Copy to .env and fill in, or export these in your shell before running the CLI
# and CDK. Nothing here is secret — these are deployment coordinates, not creds.

# AWS account ID the stacks deploy into (the CLI requires this).
#   export AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
AWS_ACCOUNT_ID=123456789012

# Region — must be one where Lambda MicroVMs is available. All resources
# (artifact bucket, image, MicroVMs) must co-locate in this region.
AWS_REGION=us-west-2

# Also used by CDK for account/region resolution.
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-west-2

# Optional overrides (sensible defaults exist in code):
# MICROVM_IMAGE_NAME=asteroids
# TABLE_NAME=AsteroidsGame
