{
  "name": "@game/game-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "test": "node --import tsx --test test/*.test.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/bundle.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\""
  },
  "dependencies": {
    "@game/shared": "*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0"
  }
}
